---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Safety in Cali" description="Essential safety tips for travelers visiting Cali, Colombia.">
    <section class="section section-light">
        <div class="container">
            <header class="tour-page-header reveal">
                <h1 style="font-size: 3.5rem; margin-bottom: 16px;">Safety in <span class="text-serif">Cali</span></h1>
                <p style="font-size: 1.2rem; color: var(--cct-text-light); max-width: 700px; margin: 0 auto;">
                    Cali is a beautiful city, and with the right precautions, you'll have an amazing and safe experience. Here are our top tips.
                </p>
            </header>

            <div class="features-grid">
                <!-- Card 1 -->
                <div class="feature-card reveal delay-1">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-check"></i>
                    </div>
                    <div>
                        <h4>Stick to Safe Areas</h4>
                        <p>Stay in well-known neighborhoods like San Antonio, Granada, El Peñón, and Ciudad Jardín. These areas are popular with tourists and well-patrolled.</p>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="feature-card reveal delay-2">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-car-side"></i>
                    </div>
                    <div>
                        <h4>Use Trusted Transport</h4>
                        <p>Use InDrive, Uber or DiDi instead of hailing taxis on the street. Always verify the driver and vehicle details before getting in.</p>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="feature-card reveal delay-3">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <div>
                        <h4>Don't Flash Valuables</h4>
                        <p>Keep your phone and wallet out of sight on the street. Use a simple bag and leave expensive jewelry at home.</p>
                    </div>
                </div>

                <!-- Card 4 -->
                <div class="feature-card reveal delay-1">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-users"></i>
                    </div>
                    <div>
                        <h4>Travel with a Local</h4>
                        <p>Having a local guide dramatically increases your safety. We know which areas to avoid and how to navigate the city like a pro.</p>
                    </div>
                </div>

                <!-- Card 5 -->
                <div class="feature-card reveal delay-2">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <div>
                        <h4>Emergency Numbers</h4>
                        <p>Police: 123 | Ambulance: 125 | Fire: 119 | Tourist Police: (2) 886-1313. Save these in your phone before arriving.</p>
                    </div>
                </div>

                <!-- Card 6 -->
                <div class="feature-card reveal delay-3">
                    <div class="feature-icon f-pink">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div>
                        <h4>Know Your Location</h4>
                        <p>Always have the address of your accommodation written down. Share your live location with someone you trust while exploring.</p>
                    </div>
                </div>
            </div>

            <div class="reveal" style="margin-top: 60px; text-align: center;">
                <a href="/contact" class="btn btn-primary">Book a Safe Guided Tour</a>
            </div>
        </div>
    </section>
</BaseLayout>
